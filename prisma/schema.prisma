// Calisthenics Tracker - Prisma schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A user account (created via Google OAuth, email/password, or demo sign-in).
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exercises  Exercise[]
  workouts   Workout[]
  categories Category[]
}

/// A custom exercise category (Push, Pull, Legs, or user-created ones).
/// Seeded with defaults for each new user.
model Category {
  id        String   @id @default(cuid())
  name      String
  label     String
  color     String   @default("#9ca3af")
  emoji     String   @default("•")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

/// A tracked calisthenics exercise (e.g. Planche, Pull-up, Pistol Squat)
model Exercise {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("Push")
  muscleGroup String   @default("Full body")
  isStatic    Boolean  @default(false)
  description String?
  equipment   String?
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  variants      ExerciseVariant[]
  workoutEntries WorkoutEntry[]

  @@unique([name, userId])
  @@index([category])
  @@index([userId])
}

/// A progression variant of an exercise (Tuck, Advanced Tuck, Straddle, Full...)
model ExerciseVariant {
  id              String   @id @default(cuid())
  exerciseId      String
  name            String
  difficultyLevel Int      @default(1)
  description     String?
  targetValue     Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  exercise       Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  workoutEntries WorkoutEntry[]
  workoutSets    WorkoutSet[]

  @@unique([exerciseId, name])
  @@index([exerciseId])
}

/// A logged training session
model Workout {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  title     String?
  durationMin Int?
  perceivedExertion Int?
  bodyweightKg Float?
  notes     String?
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries WorkoutEntry[]

  @@index([date])
  @@index([userId])
}

/// An exercise (with optional variant) performed inside a workout
model WorkoutEntry {
  id         String   @id @default(cuid())
  workoutId  String
  exerciseId String
  variantId  String?
  supersetGroup Int?
  position   Int      @default(0)
  notes      String?
  createdAt  DateTime @default(now())

  workout   Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise  Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  variant   ExerciseVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  sets      WorkoutSet[]

  @@index([workoutId])
  @@index([exerciseId])
}

/// A single set within a workout entry
model WorkoutSet {
  id              String   @id @default(cuid())
  workoutEntryId  String
  setNumber       Int
  variantId       String?
  reps            Int?
  holdSeconds     Int?
  weightKg        Float?
  rpe             Int?
  createdAt       DateTime @default(now())

  workoutEntry WorkoutEntry     @relation(fields: [workoutEntryId], references: [id], onDelete: Cascade)
  variant      ExerciseVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([workoutEntryId])
}
